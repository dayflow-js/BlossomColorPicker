{
  "name": "blossom-color-picker-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "A beautiful, blooming color picker for Web",
  "homepage": "https://github.com/dayflow-js/BlossomColorPicker#readme",
  "bugs": {
    "url": "https://github.com/dayflow-js/BlossomColorPicker/issues"
  },
  "license": "MIT",
  "author": "Jayce Li",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dayflow-js/BlossomColorPicker.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "bump:all": "./scripts/bump_all.sh",
    "dev": "vite --host --port 5177",
    "dev:packages": "pnpm -r dev",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepare": "lefthook install",
    "publish:all": "./scripts/publish.sh all",
    "publish:angular": "./scripts/publish.sh angular",
    "publish:dry": "./scripts/publish.sh all --dry-run",
    "publish:main": "./scripts/publish.sh main",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.7.0",
    "lefthook": "2.1.4",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vite": "^5.4.20",
    "vite-plugin-dts": "^4.5.4"
  }
}
